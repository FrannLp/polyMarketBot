# ============================================================
# .env.example — Copia este archivo a .env y rellena tus claves
# ============================================================

# ── Polymarket credentials ──────────────────────────────────
# CLOB (órdenes): Settings → API — no sirven solas para el relayer / autoclaim
POLYMARKET_API_KEY=tu-api-key
POLYMARKET_API_SECRET=tu-api-secret
POLYMARKET_PASSPHRASE=tu-passphrase
# Relayer / autoclaim (poly5m): Settings → API → crear Relayer API Key
POLYMARKET_RELAYER_API_KEY=tu-relayer-api-key-aqui
# Dirección que “posee” esa clave (normalmente tu EOA de firma, igual que la del PRIVATE_KEY abajo)
POLYMARKET_RELAYER_API_KEY_ADDRESS=0xTU_EOA_SIGNER
POLYMARKET_PROXY_WALLET=0xTU_PROXY_WALLET
POLYMARKET_PRIVATE_KEY=0xTU_PRIVATE_KEY
# Opcional — solo si estás en Builder Program (Settings → Builder)
# POLY_BUILDER_API_KEY=
# POLY_BUILDER_SECRET=
# POLY_BUILDER_PASSPHRASE=

# ── Copy traders (opcional) ─────────────────────────────────
TOP_TRADERS=0x0000000000000000000000000000000000000000

# ── Telegram (para alertas del bot) ─────────────────────────
# Crea un bot con @BotFather y obtén el chat_id con @userinfobot
TELEGRAM_TOKEN=tu-bot-token
TELEGRAM_CHAT_ID=tu-chat-id

# ── Bot CLIMA v2 (python bot.py) ────────────────────────────
# Sources: ECMWF + HRRR (US) + METAR — EV + Kelly Criterion
# Estado: logs/weather_state.json
WEATHER_DRY_RUN=true
WEATHER_INITIAL_BALANCE=100.00
WEATHER_BET_SIZE=1.00          # Kelly cap máximo por apuesta
WEATHER_MIN_EV=0.05            # Expected Value mínimo
WEATHER_MAX_PRICE=0.45         # No entrar si el mercado ya está por encima
WEATHER_MIN_VOLUME=2000        # Skip mercados con poco volumen
WEATHER_MIN_HOURS=2.0          # No entrar a <2h de resolución
WEATHER_MAX_HOURS=72.0         # No entrar a >72h (pronóstico poco confiable)
WEATHER_KELLY_FRACTION=0.25    # 1/4 Kelly (conservador)
WEATHER_MAX_SLIPPAGE=0.03      # Skip si spread > 3¢
WEATHER_MAX_DAILY_BETS=5
WEATHER_DAILY_STOP_LOSS=10.00
WEATHER_STOP_LOSS_PCT=0.20     # Cerrar si precio cae 20% desde entrada
VC_KEY=TU_VISUAL_CROSSING_KEY  # Gratis en visualcrossing.com

# ── Bot CLIMA v1 legacy (no usar, mantener para compatibilidad) ──────────────
BOT_NAME=SIM
DRY_RUN=true
INITIAL_BALANCE=20.00
BET_SIZE=0.50
MIN_EDGE=0.08
MAX_DAILY_BETS=10
DAILY_STOP_LOSS=3.00

# ── Bot CRYPTO general (python crypto_bot.py) ───────────────
CRYPTO_INITIAL_BALANCE=200.00
CRYPTO_BET_SIZE=5.00
CRYPTO_MIN_EDGE=0.07
CRYPTO_MAX_DAILY_BETS=20
CRYPTO_DAILY_STOP_LOSS=30.00

# ── Bot 5-MINUTOS (python cryp_signal_5minutes.py) ──────────
# REGLA CRITICA: DRY_RUN=false SOLO tras 200+ trades con WR >= 56%
# NO repetir DRY_RUN aqui abajo — python-dotenv usa el ultimo valor y haria override
CRYP5M_INITIAL_BALANCE=25.00
CRYP5M_BET_SIZE=2.50
CRYP5M_MIN_EDGE=0.08
CRYP5M_MAX_DAILY_BETS=200
CRYP5M_DAILY_STOP_LOSS=300.00
CRYP5M_MAX_BETS_PER_CYCLE=1
CRYP5M_MAX_PRICE=0.65
CRYP5M_MIN_MOMENTUM=0.05
# Filtros por asset: any | macd_cross | cvd_div | none
CRYP5M_SIGNAL_BTC=any
CRYP5M_SIGNAL_XRP=any
CRYP5M_SIGNAL_ETH=any
CRYP5M_SIGNAL_SOL=any
CRYP5M_SIGNAL_DOGE=any
CRYP5M_SIGNAL_HYPE=any

# ── Bot POLY-5M (python poly5m_bot.py) — solo CLOB Polymarket ────────────────
POLY5M_DRY_RUN=true
POLY5M_INITIAL_BALANCE=25.00
POLY5M_BET_SIZE=2.50
POLY5M_BET_SIZE_BTC=1.00
POLY5M_BET_SIZE_OTHER=1.50
POLY5M_MIN_SHARES=5.0
POLY5M_MIN_EDGE=0.06
POLY5M_MAX_DAILY_BETS=200
POLY5M_DAILY_STOP_LOSS=300.00
POLY5M_MAX_PRICE=0.65
POLY5M_MIN_BOOK_DEPTH=500
POLY5M_MAX_SLIP=0.05
# Autoclaim: mismo relayer que Polymarket (proxy Magic = PROXY; wallet Gnosis Safe = SAFE)
POLY5M_RELAYER_URL=https://relayer-v2.polymarket.com
POLY5M_RELAYER_TX_TYPE=PROXY
