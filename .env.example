# ============================================================
# .env.example — Copia este archivo a .env y rellena tus claves
# ============================================================

# ── Polymarket credentials ──────────────────────────────────
# Obten estas en: https://polymarket.com → Settings → API
POLYMARKET_RELAYER_API_KEY=tu-relayer-api-key-aqui
POLYMARKET_RELAYER_API_KEY_ADDRESS=0xTU_WALLET_ADDRESS
POLYMARKET_PROXY_WALLET=0xTU_PROXY_WALLET
POLYMARKET_PRIVATE_KEY=0xTU_PRIVATE_KEY
POLYMARKET_API_KEY=tu-api-key
POLYMARKET_API_SECRET=tu-api-secret
POLYMARKET_PASSPHRASE=tu-passphrase

# ── Copy traders (opcional) ─────────────────────────────────
TOP_TRADERS=0x0000000000000000000000000000000000000000

# ── Telegram (para alertas del bot) ─────────────────────────
# Crea un bot con @BotFather y obtén el chat_id con @userinfobot
TELEGRAM_TOKEN=tu-bot-token
TELEGRAM_CHAT_ID=tu-chat-id

# ── Bot CLIMA (python bot.py) ───────────────────────────────
BOT_NAME=SIM
DRY_RUN=true
INITIAL_BALANCE=20.00
BET_SIZE=0.50
MIN_EDGE=0.08
MAX_DAILY_BETS=10
DAILY_STOP_LOSS=3.00

# ── Bot CRYPTO general (python crypto_bot.py) ───────────────
CRYPTO_INITIAL_BALANCE=200.00
CRYPTO_BET_SIZE=5.00
CRYPTO_MIN_EDGE=0.07
CRYPTO_MAX_DAILY_BETS=20
CRYPTO_DAILY_STOP_LOSS=30.00

# ── Bot 5-MINUTOS (python cryp_signal_5minutes.py) ──────────
# REGLA CRITICA: DRY_RUN=false SOLO tras 200+ trades con WR >= 56%
# NO repetir DRY_RUN aqui abajo — python-dotenv usa el ultimo valor y haria override
CRYP5M_INITIAL_BALANCE=25.00
CRYP5M_BET_SIZE=2.50
CRYP5M_MIN_EDGE=0.08
CRYP5M_MAX_DAILY_BETS=200
CRYP5M_DAILY_STOP_LOSS=300.00
CRYP5M_MAX_BETS_PER_CYCLE=1
CRYP5M_MAX_PRICE=0.65
CRYP5M_MIN_MOMENTUM=0.05
# Filtros por asset: any | macd_cross | cvd_div | none
CRYP5M_SIGNAL_BTC=any
CRYP5M_SIGNAL_XRP=any
CRYP5M_SIGNAL_ETH=any
CRYP5M_SIGNAL_SOL=any
CRYP5M_SIGNAL_DOGE=any
CRYP5M_SIGNAL_HYPE=any
